# Copy this file to `frontend/.env` and fill in real values.
# IMPORTANT: this file must live in `frontend/` (the Vite root), not in `frontend/src/`.
# On Vercel, set these same variables in Project → Settings → Environment Variables.

# Base URL for the FastAPI backend (empty = same-origin / Vite proxy in dev).
VITE_API_BASE=https://your-backend.onrender.com

# MapMyIndia / Mappls Map SDK key (public client key).
# The key must whitelist your deployed domain in the Mappls console
# (Account → Project → Referer URLs), e.g. https://your-app.vercel.app
VITE_MAPPLS_KEY=your_mappls_map_sdk_key
